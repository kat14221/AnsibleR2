#!/usr/bin/env bash
set -euo pipefail

CORE_BRIDGE="{{ core_bridge }}"
SYSCTL_CONF="{{ core_l3_sysctl_conf_path }}"

if [[ "$(id -u)" -ne 0 ]]; then
  echo "ERROR: este script debe ejecutarse como root"
  exit 1
fi

if ! ovs-vsctl br-exists "${CORE_BRIDGE}" 2>/dev/null; then
  echo "ERROR: el bridge OVS ${CORE_BRIDGE} no existe. No se debe continuar."
  exit 1
fi

echo "[JHALEX] CORE L3: asegurando SVIs en ${CORE_BRIDGE}"

{% for svi in svis %}
ovs-vsctl --may-exist add-port "${CORE_BRIDGE}" "{{ svi.ifname }}" \
  -- set interface "{{ svi.ifname }}" type=internal \
  -- set port "{{ svi.ifname }}" tag={{ svi.vlan }}

ip link set "{{ svi.ifname }}" up || true
ip addr replace {{ svi.real_ip }}/{{ svi.prefix }} dev "{{ svi.ifname }}"
{% endfor %}

echo "[JHALEX] CORE L3: habilitando IPv4 forwarding (runtime + persistente)"
sysctl -w net.ipv4.ip_forward=1 >/dev/null

cat > "${SYSCTL_CONF}" <<'EOF'
net.ipv4.ip_forward=1
EOF

echo "[JHALEX] CORE L3: asegurando rutas default con métricas"
{% for r in default_routes %}
ip route del default via {{ r.via }} dev {{ r.dev }} 2>/dev/null || true
ip route replace default via {{ r.via }} dev {{ r.dev }} metric {{ r.metric }}
{% endfor %}

echo "[JHALEX] CORE L3: aplicado (SVIs + sysctl + rutas)"
