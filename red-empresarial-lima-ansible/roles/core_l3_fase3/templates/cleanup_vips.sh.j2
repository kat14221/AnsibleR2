#!/usr/bin/env bash
set -euo pipefail

if [[ "$(id -u)" -ne 0 ]]; then
  echo "ERROR: este script debe ejecutarse como root"
  exit 1
fi

echo "[JHALEX] CORE L3: limpiando VIPs virtuales antiguos o duplicados"
{% for svi in svis %}
ip addr del {{ svi.vip }}/{{ svi.prefix }} dev {{ svi.ifname }} 2>/dev/null || true
{% endfor %}

echo "[JHALEX] CORE L3: limpieza de VIPs completada"
