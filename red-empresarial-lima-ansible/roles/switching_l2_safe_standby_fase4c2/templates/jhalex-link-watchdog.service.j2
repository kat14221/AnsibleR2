[Unit]
Description=JHALEX Link Failover Watchdog (Fase 4C.2)
After=network-online.target jhalex-swcorelim1-ovs.service jhalex-swcorelim2-ovs.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/sbin/jhalex-link-watchdog
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
