#
# baresip configuration
#

#------------------------------------------------------------------------------
# Core
#------------------------------------------------------------------------------
poll_method		epoll		# poll, select, epoll ..

# SIP
sip_listen		0.0.0.0:0
sip_verify_server	no

# Call
call_local_timeout	120
call_max_calls		4

# Audio
audio_path		/usr/share/baresip
audio_player		aufile,aufile
audio_source		aufile,aufile
audio_alert		aufile,aufile

# Modules
module_path		{{ fase11c_baresip_module_path }}

# SIP core modules
module			account.so
module			contact.so

# Audio codec
module			g711.so

# Audio driver
module			aufile.so

# Network
module			stun.so
module			turn.so
module			ice.so
