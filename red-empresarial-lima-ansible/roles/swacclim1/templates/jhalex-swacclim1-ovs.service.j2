#!/usr/bin/bash

# =============================================================================
# SERVICIO SYSTEMD: jhalex-swacclim1-ovs.service
# =============================================================================
[Unit]
Description=JHALEX OVS Configuration Service para SWACCLIM1
After=network.target openvswitch-switch.service
Wants=openvswitch-switch.service

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/jhalex-swacclim1-ovs.sh
User=root
Group=root
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
